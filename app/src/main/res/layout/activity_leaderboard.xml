<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".LeaderBoard">

    <TextView
        android:id="@+id/leaderBoardTitle"
        android:layout_width="match_parent"
        android:gravity="center"
        android:layout_height="wrap_content"
        android:textSize="@dimen/difTextSize"
        android:textStyle="bold"
        android:layout_margin="@dimen/difTextSize"
        android:text="LeaderBoard" />

        <TextView
            android:id="@+id/multiplicationScore"
            android:layout_width="match_parent"
            android:layout_margin="@dimen/difTextSize"
            android:textSize="@dimen/textSize"
            android:layout_height="wrap_content"
            android:text="Multiplication High Score:" />
        <TextView
            android:id="@+id/memoryScore"
            android:layout_width="match_parent"
            android:layout_margin="@dimen/difTextSize"
            android:textSize="@dimen/textSize"
            android:layout_height="wrap_content"
            android:text="Memory High Score:" />
        <TextView
            android:id="@+id/wordScore"
            android:layout_width="match_parent"
            android:layout_margin="@dimen/difTextSize"
            android:textSize="@dimen/textSize"
            android:layout_height="wrap_content"
            android:text="Word High Score:" />

    <Button
        android:id="@+id/leaderboardReset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="@dimen/difTextSize"
        android:text="Reset Scores" />

    <Button
        android:id="@+id/button3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="@dimen/difTextSize"
        android:text="Exit" />


</LinearLayout>